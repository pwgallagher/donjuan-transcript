# Auto detect text files and normalize to LF in repo
* text=auto

# Explicit text files
*.html text
*.css text
*.js text
*.txt text
*.xml text
*.json text
*.md text

# Binary files - do not modify line endings
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.svg binary
*.ico binary
*.woff binary
*.woff2 binary
*.pdf binary

# Force LF for critical files so crawlers don't choke on CRLF
/robots.txt text eol=lf
/llms.txt text eol=lf
/sitemap.xml text eol=lf
/LICENSE text eol=lf

